# --- Dashboard session (optional metadata) ---
# No keys required for "Free AI" username login.

# --- OAuth device flow (LLM) ---
# GitHub: built-in client id — no env required for device flow.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_AZURE_CLIENT_ID=

# --- LLM API keys (any one or more enables corresponding models in UI) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
SAMBANOVA_API_KEY=

# Local Ollama (OpenAI-compatible)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Kiro aggregator (OpenAI-compatible). Same plug-and-play model as wiring
# Visual Studio / Copilot to a custom provider: drop in your key and pick a
# model in Settings → Models. Override KIRO_BASE_URL only for self-hosted /
# private deployments.
KIRO_API_KEY=
KIRO_BASE_URL=

# --- Other providers (manual agent config / extended use) ---
# Set on agent model config if not in default UI list:
# PERPLEXITY, HUGGINGFACE, MINIMAX, MOONSHOT, HYPERBOLIC, COHERE, LEPTON, etc.

# --- Infra ---
SOLANA_RPC_URL=
HELIUS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
